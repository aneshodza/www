# Umami analytics (cookieless, self-hosted at analytics.centrolabs.ch).
# These default to the production values in src/layouts/Layout.astro, so you only
# need to set them here to override (e.g. point dev at a different instance, or
# blank them out to disable analytics locally). Both must be set for analytics to load.
PUBLIC_UMAMI_WEBSITE_ID=
PUBLIC_UMAMI_SRC=
