# Copy to .env and fill in. All keys are PUBLIC_* (baked into the client build,
# not secrets). In CI they are set as GitHub Actions repository *variables*.

# Umami analytics (cookieless, self-hosted). Both must be set for analytics
# to load; leave blank to disable analytics for this build.
PUBLIC_UMAMI_WEBSITE_ID=
PUBLIC_UMAMI_SRC=

# Formbricks contact form (self-hosted public client API). All three required
# for the form to submit. The survey needs four open-text questions whose
# Question IDs are: name, email, subject, message.
PUBLIC_FORMBRICKS_APP_URL=
PUBLIC_FORMBRICKS_ENVIRONMENT_ID=
PUBLIC_FORMBRICKS_SURVEY_ID=
