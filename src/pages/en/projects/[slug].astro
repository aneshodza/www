---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/Layout.astro';
import ProjectView from '~/components/pages/ProjectView.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects', (e) => e.data.locale === 'en');
  return projects.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
---

<Layout title={entry.data.title} description={entry.data.summary}>
  <ProjectView entry={entry} />
</Layout>
