---
import { getLocaleFromUrl, useTranslations, localizePath } from '~/i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<section class="mx-auto max-w-[68rem] px-6 md:px-10 pt-20 pb-24 min-h-[60vh]">
  <p class="label">404</p>
  <h1 class="display text-[3rem] md:text-[4.5rem] mt-6 max-w-[40rem]">
    {t('404.title')}.
  </h1>
  <p class="mt-8 max-w-[36rem] text-[var(--fg-muted)] text-[1.125rem] leading-relaxed">
    {t('404.body')}
  </p>
  <p class="mt-10">
    <a href={localizePath('/', locale)} class="btn-text">
      {t('404.home')} &nbsp;&rarr;
    </a>
  </p>
</section>
