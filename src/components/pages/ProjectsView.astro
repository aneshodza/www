---
import { getCollection } from 'astro:content';
import ProjectCard from '~/components/ProjectCard.astro';
import { getLocaleFromUrl, useTranslations, localizePath } from '~/i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const projects = (
  await getCollection('projects', (e) => e.data.locale === locale)
).sort((a, b) => a.data.order - b.data.order);

const tier1 = projects.slice(0, 1);
const tier2 = projects.slice(1, 3);
const tier3 = projects.slice(3);
---

<section class="mx-auto max-w-[68rem] px-5 md:px-10 pt-12 md:pt-20 pb-10">
  <div class="flex items-baseline justify-between border-b border-[var(--rule)] pb-3 mb-10">
    <p class="label">{t('nav.projects')}</p>
    <p class="font-sans text-[0.72rem] uppercase tracking-[0.14em] text-[var(--fg-subtle)]">
      {String(projects.length).padStart(2, '0')} {locale === 'de' ? 'Einträge' : 'Entries'}
    </p>
  </div>

  <h1 class="display text-[2.25rem] sm:text-[2.5rem] md:text-[3.25rem] max-w-[40rem] leading-[1.05]">
    {locale === 'de' ? 'Projekte und Veröffentlichungen.' : 'Projects and releases.'}
  </h1>
  <p class="mt-6 max-w-[36rem] text-[var(--fg-muted)] text-[1.0625rem] md:text-[1.125rem] leading-relaxed">
    {locale === 'de'
      ? 'Eine Auswahl von Projekten, an welchen ich gearbeitet habe.'
      : 'A selection of projects I have worked on.'}
  </p>
</section>

{tier1.length > 0 && (
  <section class="mx-auto max-w-[68rem] px-5 md:px-10 py-12 md:py-16 border-t border-[var(--rule)]">
    <div class="flex items-baseline justify-between border-b border-[var(--rule)] pb-3 mb-10">
      <h2 class="label">{t('sections.featured')}</h2>
      <p class="font-sans text-[0.72rem] uppercase tracking-[0.14em] text-[var(--fg-subtle)]">
        Tier I
      </p>
    </div>
    {tier1.map((entry) => (
      <ProjectCard entry={entry} featured />
    ))}
  </section>
)}

{tier2.length > 0 && (
  <section class="mx-auto max-w-[68rem] px-5 md:px-10 py-12 md:py-16 border-t border-[var(--rule)]">
    <div class="flex items-baseline justify-between border-b border-[var(--rule)] pb-3 mb-10">
      <h2 class="label">{locale === 'de' ? 'Weitere Schwerpunkte' : 'Further work'}</h2>
      <p class="font-sans text-[0.72rem] uppercase tracking-[0.14em] text-[var(--fg-subtle)]">
        Tier II
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-14">
      {tier2.map((entry, i) => (
        <ProjectCard entry={entry} index={i + 1} />
      ))}
    </div>
  </section>
)}

{tier3.length > 0 && (
  <section class="mx-auto max-w-[68rem] px-5 md:px-10 py-12 md:py-16 border-t border-[var(--rule)]">
    <div class="flex items-baseline justify-between border-b border-[var(--rule)] pb-3 mb-10">
      <h2 class="label">{locale === 'de' ? 'Engineering-Notizen' : 'Engineering notes'}</h2>
      <p class="font-sans text-[0.72rem] uppercase tracking-[0.14em] text-[var(--fg-subtle)]">
        Tier III
      </p>
    </div>
    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-12 gap-y-3">
      {tier3.map((entry, i) => {
        const href = localizePath(`/projects/${entry.data.slug}`, locale);
        return (
          <li class="flex items-baseline gap-4 border-b border-[var(--rule)] py-5">
            <span class="font-sans text-[0.72rem] tracking-[0.14em] uppercase text-[var(--fg-subtle)] tabular-nums">
              {String(i + 4).padStart(2, '0')}
            </span>
            <div class="flex-1">
              <h3 class="font-serif text-[1.1rem] md:text-[1.2rem] font-semibold tracking-tight">
                <a
                  href={href}
                  class="hover:text-[var(--accent)] transition-colors"
                >
                  {entry.data.title}
                </a>
              </h3>
              <p class="font-serif italic text-[0.95rem] text-[var(--fg-muted)] mt-1 max-w-[34rem] leading-snug">
                {entry.data.summary}
              </p>
              <ul class="mt-2 flex flex-wrap gap-x-3 gap-y-1">
                {entry.data.tech.slice(0, 4).map((tag) => (
                  <li class="tag">{tag}</li>
                ))}
              </ul>
            </div>
          </li>
        );
      })}
    </ul>
  </section>
)}
