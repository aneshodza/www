---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';

interface Props {
  entry: CollectionEntry<'experience'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<article class="grid grid-cols-1 md:grid-cols-[14rem_1fr] gap-3 md:gap-10 py-8 border-t border-[var(--rule)] first:border-t-0 first:pt-0">
  <header>
    <p class="font-sans text-[0.72rem] uppercase tracking-[0.14em] text-[var(--fg-subtle)]">
      {entry.data.period}
    </p>
    <p class="font-serif text-[0.92rem] italic text-[var(--fg-muted)] mt-1">
      {entry.data.location}
    </p>
  </header>

  <div>
    <h3 class="font-serif text-[1.25rem] font-semibold tracking-tight">
      {entry.data.role}
      <span class="text-[var(--fg-subtle)] font-normal"> &middot; </span>
      <span class="font-normal italic">{entry.data.company}</span>
    </h3>

    <div class="prose-editorial mt-3 max-w-none">
      <Content />
    </div>

    {
      entry.data.tech.length > 0 && (
        <ul class="mt-4 flex flex-wrap gap-x-3 gap-y-1">
          {entry.data.tech.map((t) => <li class="tag">{t}</li>)}
        </ul>
      )
    }
  </div>
</article>
