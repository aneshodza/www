---
import { getLocaleFromUrl, useTranslations } from '~/i18n/utils';
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const labels = {
  de: { light: 'Hell', dark: 'Dunkel' },
  en: { light: 'Light', dark: 'Dark' },
} as const;
const l = labels[locale];
---

<button
  id="theme-toggle"
  type="button"
  class="theme-toggle inline-flex items-center min-h-[44px] md:min-h-0 px-1 font-sans text-[0.72rem] uppercase tracking-[0.14em] text-[var(--fg-subtle)] hover:text-[var(--accent)] transition-colors"
  aria-label={t('theme.toggle')}
  aria-pressed="false"
>
  <span data-theme-label-light>{l.light}</span>
  <span data-theme-label-dark class="hidden">{l.dark}</span>
</button>

<script is:inline>
  (() => {
    const bind = () => {
      const btn = document.getElementById('theme-toggle');
      if (!btn || btn.dataset.themeBound === '1') return;
      btn.dataset.themeBound = '1';
      const update = () => {
        const isDark = document.documentElement.classList.contains('dark');
        btn.setAttribute('aria-pressed', String(isDark));
        const lightLabel = btn.querySelector('[data-theme-label-light]');
        const darkLabel = btn.querySelector('[data-theme-label-dark]');
        if (lightLabel) lightLabel.classList.toggle('hidden', isDark);
        if (darkLabel) darkLabel.classList.toggle('hidden', !isDark);
      };
      btn.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        try {
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        } catch {}
        update();
      });
      update();
    };
    bind();
    document.addEventListener('astro:page-load', bind);
  })();
</script>
