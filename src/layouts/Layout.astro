---
import '~/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import CookieNotice from '~/components/CookieNotice.astro';
import {
  getLocaleFromUrl,
  useTranslations,
  switchLocalePath,
} from '~/i18n/utils';

interface Props {
  title?: string;
  description?: string;
  ogType?: string;
}

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const { title, description, ogType = 'website' } = Astro.props;

const pageTitle = `${title ?? t('nav.home')} | Anes`;
const metaDescription = description ?? t('site.description');

const altLocale = locale === 'de' ? 'en' : 'de';
const altPath = switchLocalePath(Astro.url.pathname, altLocale);
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
const altUrl = new URL(altPath, Astro.site ?? Astro.url.origin).toString();
const socialImage = new URL('/og.png', Astro.site ?? Astro.url.origin).toString();

const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;
const umamiSrc = import.meta.env.PUBLIC_UMAMI_SRC;
const umamiEnabled = Boolean(umamiWebsiteId && umamiSrc);

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Anes Hodza',
  url: 'https://aneshodza.ch',
  image: new URL('/portrait.jpg', Astro.site ?? Astro.url.origin).toString(),
  jobTitle: t('hero.tagline'),
  email: 'mailto:anes@centrolabs.ch',
  sameAs: [
    'https://github.com/aneshodza',
    'https://www.linkedin.com/in/aneshodza/',
    'https://dev.to/aneshodza',
    'https://www.npmjs.com/~aneshodza',
  ],
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'CH',
  },
  alumniOf: {
    '@type': 'EducationalOrganization',
    name: 'ZHAW Zurich University of Applied Sciences',
  },
  worksFor: {
    '@type': 'Organization',
    name: 'Centro Labs',
    url: 'https://centrolabs.ch',
  },
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#fbfaf7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#14110d" media="(prefers-color-scheme: dark)" />
    <title>{pageTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta name="author" content="Anes Hodza" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={altLocale} href={altUrl} />
    <link rel="alternate" hreflang={locale} href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={locale === 'de' ? 'de_CH' : 'en_GB'} />
    <meta property="og:site_name" content="Anes Hodza" />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={socialImage} />

    <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />

    {
      umamiEnabled && (
        <>
          <script
            defer
            src={umamiSrc}
            data-website-id={umamiWebsiteId}
            data-auto-track="false"
          />
          <script is:inline>
            {`(() => {
              const track = () => { if (window.umami) window.umami.track(); };
              if (!window.__umamiBound) {
                window.__umamiBound = true;
                document.addEventListener('astro:page-load', track);
              }
            })();`}
          </script>
        </>
      )
    }

    <ClientRouter />

    <script is:inline>
      (() => {
        const apply = () => {
          try {
            const stored = localStorage.getItem('theme');
            const prefersDark =
              window.matchMedia &&
              window.matchMedia('(prefers-color-scheme: dark)').matches;
            const isDark = stored ? stored === 'dark' : prefersDark;
            document.documentElement.classList.toggle('dark', isDark);
          } catch {}
        };
        apply();
        document.addEventListener('astro:after-swap', apply);
      })();
    </script>
  </head>
  <body class="min-h-dvh flex flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:bg-[var(--bg)] focus:text-[var(--fg)] focus:px-3 focus:py-2 focus:border focus:border-[var(--rule)]"
    >
      Skip to content
    </a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
    <CookieNotice />
  </body>
</html>
